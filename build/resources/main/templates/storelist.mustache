<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,300;1,400&display=swap" rel="stylesheet">
    <link href="/css/main.css?after" rel="stylesheet">
    <title>restaurant</title>
</head>
<body>

<!--head-->
<div class="detail_head">
    <img src="/img/logo.png" width="100" class="detail_head_img">
    <div class="search">
        <input style="font-size:16px; width:80%; padding:10px; border:0; outline:none; float:left;" type="text" placeholder="매장명을 입력하세요">
        <button style="height:100%; width:100px; border:0; background:rgba(0,100,0,0.76); color:#fff; font-size:16px; font-weight:bold; float:right">검색</button>
    </div>
    <div class="detail_head_list">
        <a href="#">Category&emsp;</a>
        <a href="#">MyPage</a>
    </div>
    <div class="logout">
        <a href="#">LOGOUT</a>
    </div>
</div>
<!-- Button trigger modal -->
<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal">
    Launch demo modal
</button>

<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>
<div class="category_box">

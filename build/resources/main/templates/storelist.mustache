<div class="store_list_box">
        <table style="border-spacing: 20px;">
            <thead class="Store" >
            <tr>
    <!--            <th>이미지</th>-->
                <th>이름</th>
                <th>시간</th>
                <th>전화번호</th>
                <th>별점</th>
            </tr>
            </thead>
            <tbody id="tbody">
            {{#list}}
                <tr>
    <!--                <td>{{store_img}}</td>-->
                    <td><a href="/rest/{{id}}">{{store_name}}</a></td>
                    <td>{{store_time}}</td>
                    <td>{{store_phone}}</td>
                    <td>{{store_star}}</td>
                </tr>
            {{/list}}
            </tbody>
        </table>

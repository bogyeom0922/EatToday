{{>layouts/detail_header}}

<div class="background"></div>
<img src="/img/sample.jpeg" class="rest_img">
<div class="background2"></div>

<div class="store_name">
    {{#rest}}{{store_name}}{{/rest}}
</div>
<div class="subtitle">
    별점 {{#rest}}{{store_star}}{{/rest}}&emsp;&emsp;&emsp;&emsp;리뷰 개
</div>

<div class="rest_detail">
    {{#rest}}
        주소&emsp;&emsp;: {{store_address}}<br>
        대표번호 : {{store_phone}}<br>
        영업시간 : {{store_time}}<br>
        {{store_menu}}<br>
        {{review_content}}<br>
    {{/rest}}
</div>


<form>
    <div>
        <label>리뷰</label>
        <textarea type="text" rows="3" id="new-review-body"></textarea>
    </div>
{{#rest}}
        <input type="hidden" id="new-review-store-id" value="{{id}}">
{{/rest}}
    <button type="button" id="review-create-btn">댓글작성</button>
</form>

{{>layouts/footer}}

<script>
    {
        const reviewCreateBtn = document.querySelector("#review-create-btn");
        reviewCreateBtn.addEventListener("click", function() {
            const review = {
                body: document.querySelector("#new-review-body").value,
                storeId: document.querySelector("#new-review-store-id").value
            };
            console.log(review);

            const url = "/api/store/" + review.storeId + "/review";
            fetch(url, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(review)
            });
        });
    }
</script>